# Library Management System - Configuration Template
# 
# ⚠️  IMPORTANT: 
# - Copy this file as ".env" in same folder as library_system.py
# - DO NOT commit .env to git (it's in .gitignore)
# - Production server par apna actual credentials daalna
#
# LOCAL DEVELOPMENT:
GOOGLE_BOOKS_API_KEY=your_api_key
DB_HOST=localhost
DB_PORT=5432
DB_NAME=library_db
DB_USER=postgres
DB_PASSWORD=system

# 
# PRODUCTION SERVER (Example):
# ────────────────────────────────────────
# GOOGLE_BOOKS_API_KEY=AIzaSycXXXXXXXXX   (new key generate karo)
# DB_HOST=prod-db.azurewebsites.net       (or AWS RDS endpoint)
# DB_PORT=5432
# DB_NAME=library_db
# DB_USER=prod_admin
# DB_PASSWORD=StrongPasswordHere_123!@#
#
# Connection String Example (Azure PostgreSQL):
# postgresql://prod_admin:password@prod-db.azurewebsites.net:5432/library_db
